import { useParams, useNavigate } from 'react-router-dom';
import { AudioPlayer } from '../components/AudioPlayer';
import { Transcript } from '../components/Transcript';
import { CallTimeline } from '../components/CallTimeline';
import { ActionPanel } from '../components/ActionPanel';
import { useCalls } from '../context/CallsContext';
import { ArrowLeft, Calendar, User, ShieldCheck, Tag } from 'lucide-react';

export function CallDetail() {
    const { id } = useParams();
    const navigate = useNavigate();
    const { calls, loading } = useCalls();

    // Derived state
    const call = calls.find(c => c.id === id) || null;
    /* Hook handles loading state */

    if (loading) return <div className="p-8 text-center text-slate-500">Loading call details...</div>;
    if (!call) return <div className="p-8 text-center text-slate-500">Call not found</div>;

    return (
        <div className="container max-w-7xl mx-auto py-2">
            <button
                onClick={() => navigate('/calls')}
                className="flex items-center gap-2 text-sm text-slate-500 hover:text-slate-900 mb-6 transition-colors font-medium"
            >
                <ArrowLeft size={16} />
                Back to Calls
            </button>

            <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
                {/* Left Column: Player & Transcript */}
                <div className="lg:col-span-2 space-y-6">
                    <AudioPlayer />
                    <Transcript segments={call.transcript} callerName={call.patientName} />
                </div>

                {/* Right Column: Summary & Actions */}
                <div className="space-y-6">
                    {/* Summary Card */}
                    <div className="card">
                        <div className="flex items-center justify-between mb-4">
                            <h3 className="font-semibold text-lg text-slate-800">Summary</h3>
                            <span className={`badge ${call.status === 'resolved' ? 'badge-success' : 'badge-warning'}`}>
                                {call.status === 'resolved' ? 'Resolved' : 'Action Required'}
                            </span>
                        </div>

                        <div className="mb-4 text-sm text-slate-600 bg-slate-50 p-3 rounded-md border border-slate-100">
                            {call.summary}
                        </div>

                        <div className="space-y-4">
                            <div className="flex items-start gap-3">
                                <User size={16} className="text-slate-400 mt-1" />
                                <div>
                                    <div className="text-xs font-medium text-slate-500 uppercase tracking-wide">Caller</div>
                                    <div className="text-sm font-medium text-slate-900">{call.patientName || 'Unknown'}</div>
                                    <div className="text-xs text-slate-500 font-mono">{call.patientPhone}</div>
                                </div>
                            </div>

                            {call.extractedData && (
                                <>
                                    {call.extractedData.requestedDate && (
                                        <div className="flex items-start gap-3">
                                            <Calendar size={16} className="text-slate-400 mt-1" />
                                            <div>
                                                <div className="text-xs font-medium text-slate-500 uppercase tracking-wide">Requested Time</div>
                                                <div className="text-sm text-slate-700">{call.extractedData.requestedDate}</div>
                                            </div>
                                        </div>
                                    )}

                                    <div className="flex items-start gap-3">
                                        <ShieldCheck size={16} className="text-slate-400 mt-1" />
                                        <div>
                                            <div className="text-xs font-medium text-slate-500 uppercase tracking-wide">Reason</div>
                                            <div className="text-sm text-slate-700">{call.extractedData.reason}</div>
                                        </div>
                                    </div>
                                </>
                            )}

                            <div className="flex items-start gap-3 pt-2 border-t border-slate-100">
                                <Tag size={16} className="text-slate-400 mt-1" />
                                <div className="flex-1">
                                    <div className="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Tags</div>
                                    <div className="flex flex-wrap gap-1">
                                        {(call.tags || []).map(tag => (
                                            <span key={tag} className="px-2 py-0.5 bg-slate-100 text-slate-600 rounded text-xs border border-slate-200">
                                                {tag}
                                            </span>
                                        ))}
                                        <button className="text-xs text-teal-600 hover:underline px-1">+ Add</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <ActionPanel />
                    <CallTimeline events={call.timeline} />
                </div>
            </div>
        </div>
    );
}
